import pandas as pd
import numpy as np
from sklearn.preprocessing import StandardScaler
from sklearn.decomposition import PCA

df = df.sort_values('date').reset_index(drop=True)

df['neg_tone'] = -1 * df['tone']   # now higher neg_tone = more negative sentiment

features = ['news_volume', 'neg_tone', 'google_trends']

scaler = StandardScaler()
scaled_features = scaler.fit_transform(df[features])

df_scaled = pd.DataFrame(scaled_features, columns=[f'{f}_z' for f in features])
df_scaled['date'] = df['date'].values

pca = PCA(n_components=3)  # start with all 3 to inspect variance explained
principal_components = pca.fit_transform(df_scaled[[f'{f}_z' for f in features]])

explained_variance = pca.explained_variance_ratio_
print("Variance explained by each component:")
for i, var in enumerate(explained_variance):
    print(f"  PC{i+1}: {var*100:.2f}%")

print(f"\nCumulative variance (PC1 only): {explained_variance[0]*100:.2f}%")

loadings = pd.DataFrame(
    pca.components_.T,
    columns=['PC1', 'PC2', 'PC3'],
    index=features
)
print(loadings)

# PC1 is reputation index
df['reputation_index_pca'] = principal_components[:, 0]

# Sign-check: does the index go very negative during known backlash events?

if loadings['PC1'].mean() < 0:
    df['reputation_index_pca'] *= -1
    print("Flipped PC1 sign for interpretability")

print(df[['date', 'reputation_index_pca']].describe())

